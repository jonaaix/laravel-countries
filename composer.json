{
    "name": "aaix/laravel-countries",
    "description": "Modernized Laravel country-data package: idempotent seeders, zero-touch install, no interactive commands. 2026 lift of lwwcas/laravel-countries.",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Jonas Gnioui",
            "email": "jonaaix@icloud.com",
            "role": "Fork Maintainer"
        },
        {
            "name": "Lucas Duarte O. Monteiro",
            "email": "lwwcas@gmail.com",
            "homepage": "http://www.lucasduarte.dev",
            "role": "Original Author"
        }
    ],
    "keywords": [
        "laravel",
        "countries",
        "geography",
        "multilingual",
        "coordinates",
        "ISO codes",
        "country data",
        "laravel package",
        "geolocation",
        "geoJson",
        "world countries"
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": ">=11.0",
        "astrotomic/laravel-translatable": "^11.8",
        "spatie/laravel-package-tools": "^1.92"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.12|^10.0",
        "pestphp/pest": "^3.7",
        "pestphp/pest-plugin-laravel": "^3.1"
    },
    "autoload": {
        "psr-4": {
            "Aaix\\LaravelCountries\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aaix\\LaravelCountries\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "test-coverage": "./vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Aaix\\LaravelCountries\\Providers\\CountriesServiceProvider"
            ],
            "aliases": {
                "WCountries": "Aaix\\LaravelCountries\\Facades\\WCountries"
            }
        }
    }
}
